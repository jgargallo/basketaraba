# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# Virtualenvs
.venv/
venv/
env/

# Editors / OS
.DS_Store
.idea/
.vscode/
*.swp

# Generated data — regenerable with the pipeline:
#   python crawler.py "<group>"
#   python stats.py data/<group-slug>
#   python web/build.py data/<group-slug>/database.json
#
# raw/ = download cache, ephemeral — not committed.
# matches/ = canonical scraped data, committed so CI skips already-scraped matches.
# database.json = derived table, committed so the Pages deploy needs no scraping.
data/*
!data/*/
data/*/*
!data/*/raw/
data/*/raw/*
!data/*/matches/
!data/*/matches/*.json
!data/*/database.json
!data/*/matches.json
web/dist/

# Logs
*.log
