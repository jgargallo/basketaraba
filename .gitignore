# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# Virtualenvs
.venv/
venv/
env/

# Editors / OS
.DS_Store
.idea/
.vscode/
*.swp

# Generated data — regenerable with the pipeline:
#   python crawler.py "<group>"
#   python stats.py data/<group-slug>
#   python web/build.py data/<group-slug>/database.json
#
# Everything under data/ is ignored EXCEPT database.json files. Committing
# those lets a CI job rebuild the static site without re-crawling.
data/*
!data/*/
data/*/*
!data/*/database.json
web/dist/

# Logs
*.log
